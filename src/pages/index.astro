---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";

import { BUY_ME_COFFEE } from "../config";

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hi there 👋,</div>
    <div class="text-5xl font-bold">I'm shigatena</div>
    <div class="text-3xl py-3 font-bold">Developer and security enthusiast</div>
    <div class="py-2">
      <text class="text-lg">
        Cyber-security student <b><a href="https://www.esilv.fr/">@ESILV-Paris</a></b> and also working
        <b><a href="https://www.cnp.fr/">@CNP Assurances</a></b> as a CISO assistant.<br/>
        I'm aspiring to become a pentester or developer in offensive security.<br/>
        Find me here on <b><a href="https://www.root-me.org/shigatena">@Root-me</a></b> and
        <b><a href="https://app.hackthebox.com/users/588018">@HackTheBox</a></b> !
      </text>
    </div>
    <div class="mt-8">
      <a class="btn btn-primary" href="https://www.linkedin.com/in/enzo-de-sousa/" target="_blank">Contact me !</a>
      <a href={BUY_ME_COFFEE} target="_blank" class="btn btn-outline ml-5">Buy me a coffee :-)</a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Latest blog posts {"</>"}</div>
  </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + post.slug}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
